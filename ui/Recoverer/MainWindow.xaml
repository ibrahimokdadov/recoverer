<Window
    x:Class="Recoverer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Recoverer"
    Title="Recoverer">

    <NavigationView x:Name="NavView"
        PaneDisplayMode="Left"
        OpenPaneLength="200"
        CompactPaneLength="48"
        IsSettingsVisible="False"
        IsBackButtonVisible="Collapsed"
        SelectionChanged="NavView_SelectionChanged">

        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="NavSetup" Tag="Setup"
                Content="Scan Setup" Icon="NewFolder" />
            <NavigationViewItem x:Name="NavScanning" Tag="Scanning"
                Content="Scanning" Icon="Sync" IsEnabled="False" />
            <NavigationViewItem x:Name="NavResults" Tag="Results"
                Content="Results" Icon="List" IsEnabled="False" />
            <NavigationViewItem x:Name="NavRecovery" Tag="Recovery"
                Content="Recovery" Icon="Save" IsEnabled="False" />
        </NavigationView.MenuItems>

        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Window>
