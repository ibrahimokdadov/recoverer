<UserControl x:Class="Recoverer.Controls.FilePreviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Recoverer.Controls">

    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            Padding="16,12,16,12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Image preview -->
            <Image x:Name="ImagePreview" Grid.Column="0"
                   MaxHeight="176" Stretch="Uniform"
                   Visibility="Collapsed" />

            <!-- Text preview -->
            <ScrollViewer Grid.Column="0" x:Name="TextPreviewScroller"
                          Visibility="Collapsed" MaxHeight="176">
                <TextBlock x:Name="TextPreview"
                           FontFamily="Cascadia Code, Consolas"
                           FontSize="11"
                           TextWrapping="Wrap" />
            </ScrollViewer>

            <!-- Metadata panel -->
            <StackPanel Grid.Column="1" Margin="16,0,0,0" Spacing="4">
                <TextBlock x:Name="FileNameText"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="MetaText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Confidence:" Style="{StaticResource CaptionTextBlockStyle}" />
                    <local:ConfidenceDots x:Name="ConfidenceIndicator" />
                    <TextBlock x:Name="ConfidenceLabel"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>
                <!-- Low-confidence warning -->
                <InfoBar x:Name="LowConfidenceWarning"
                         IsOpen="False" Severity="Warning"
                         Title="Partial recovery"
                         Message="This file was partially overwritten. Recovery may produce a corrupt or incomplete file." />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
