<Page x:Class="Recoverer.Views.ResultsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:Recoverer.ViewModels"
      xmlns:local="using:Recoverer"
      xmlns:ctrl="using:Recoverer.Controls">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Filter sidebar -->
        <ScrollViewer Grid.Column="0" Grid.RowSpan="2" Padding="16,16,8,16"
                      BorderThickness="0,0,1,0"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <StackPanel Spacing="12">
                <TextBlock Text="FILE TYPE" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <HyperlinkButton Content="All types" Command="{x:Bind ViewModel.SetFilterCommand}" CommandParameter="{x:Null}" />
                <HyperlinkButton Content="Images"    Command="{x:Bind ViewModel.SetFilterCommand}" CommandParameter="Images" />
                <HyperlinkButton Content="Videos"    Command="{x:Bind ViewModel.SetFilterCommand}" CommandParameter="Videos" />
                <HyperlinkButton Content="Documents" Command="{x:Bind ViewModel.SetFilterCommand}" CommandParameter="Documents" />
                <HyperlinkButton Content="Audio"     Command="{x:Bind ViewModel.SetFilterCommand}" CommandParameter="Audio" />
                <HyperlinkButton Content="Archives"  Command="{x:Bind ViewModel.SetFilterCommand}" CommandParameter="Archives" />

                <TextBlock Text="CONFIDENCE" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,8,0,0"/>
                <HyperlinkButton Content="All" Command="{x:Bind ViewModel.SetConfidenceFilterCommand}" CommandParameter="{x:Null}" />
                <HyperlinkButton Content="High only (≥80%)" Command="{x:Bind ViewModel.SetConfidenceFilterCommand}" CommandParameter="80" />
                <HyperlinkButton Content="Good (≥50%)"      Command="{x:Bind ViewModel.SetConfidenceFilterCommand}" CommandParameter="50" />

                <Button Content="Select All High Confidence"
                        Command="{x:Bind ViewModel.SelectHighConfidenceCommand}"
                        Margin="0,8,0,0" />
            </StackPanel>
        </ScrollViewer>

        <!-- Main results area -->
        <Grid Grid.Column="1" Grid.Row="0" RowSpacing="8" Margin="16,16,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="200" />
            </Grid.RowDefinitions>

            <!-- Search bar -->
            <TextBox Grid.Row="0" x:Name="SearchBox"
                     PlaceholderText="Search by filename..."
                     TextChanged="SearchBox_TextChanged" />

            <!-- File list -->
            <ListView Grid.Row="1" x:Name="FileList"
                      ItemsSource="{x:Bind ViewModel.Files}"
                      SelectionMode="Multiple"
                      SelectionChanged="FileList_SelectionChanged">
                <ListView.Header>
                    <Grid Padding="4,4,4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="2" Text="Name" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="3" Text="Size" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="4" Text="Confidence" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="5" Text="Source" Style="{StaticResource CaptionTextBlockStyle}" />
                    </Grid>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:FileRecord">
                        <Grid Padding="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Category}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Grid.Column="1" Text="{x:Bind DisplayName}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Text="{x:Bind SizeBytes,
                                       Converter={StaticResource FileSizeConverter}}"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                            <ctrl:ConfidenceDots Grid.Column="3"
                                                 Value="{x:Bind Confidence}" />
                            <TextBlock Grid.Column="4" Text="{x:Bind Source}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Preview pane (single selection) -->
            <ctrl:FilePreviewPanel Grid.Row="2"
                File="{x:Bind ViewModel.PreviewFile, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.PreviewFile, Mode=OneWay,
                              Converter={StaticResource NullToVisConverter}}" />
        </Grid>

        <!-- Bottom action bar -->
        <Grid Grid.Column="1" Grid.Row="1"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              Padding="16,8,16,8" BorderThickness="0,1,0,0"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center">
                <Run Text="{x:Bind ViewModel.SelectedFiles.Count, Mode=OneWay}" />
                <Run Text=" of " />
                <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}" />
                <Run Text=" files selected" />
            </TextBlock>
            <Button Grid.Column="1" Content="Recover Selected →"
                    Click="RecoverButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    IsEnabled="{x:Bind ViewModel.SelectedFiles.Count,
                                 Converter={StaticResource CountToBoolConverter}, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>
