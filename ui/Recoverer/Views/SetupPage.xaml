<Page x:Class="Recoverer.Views.SetupPage"
      x:Name="SetupPageRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:Recoverer.ViewModels"
      xmlns:local="using:Recoverer">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="32,24,32,32" RowSpacing="20" MaxWidth="600">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- What makes this different -->
        <Expander Grid.Row="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                  Header="Why Recoverer is different">
            <StackPanel Spacing="10" Padding="4,8,4,4">

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE8B3;" FontSize="18"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                              VerticalAlignment="Top" Margin="0,2,0,0" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Fragment chain detection" FontWeight="SemiBold" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            Other apps show 1 000 chunks of one video as 1 000 separate files.
                            Recoverer detects consecutive carved chunks as a single chain, shows one entry,
                            and reads the full contiguous span during recovery — so you get the whole video.
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE8FA;" FontSize="18"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                              VerticalAlignment="Top" Margin="0,2,0,0" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Persistent scan sessions" FontWeight="SemiBold" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            Every scan is saved. Come back days later, browse previous results,
                            and keep recovering — no re-scan needed.
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE73E;" FontSize="18"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                              VerticalAlignment="Top" Margin="0,2,0,0" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Cross-session recovery memory" FontWeight="SemiBold" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            Recovered files are remembered by disk sector. Re-scan the same drive
                            and they're automatically pre-marked as recovered — "Hide recovered" works
                            across sessions.
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE9D9;" FontSize="18"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                              VerticalAlignment="Top" Margin="0,2,0,0" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Honest confidence scoring" FontWeight="SemiBold" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            Header-only finds: 45%. Footer-confirmed: 65%. MFT-backed: 75%.
                            Most apps hide or homogenise confidence — this one shows you exactly
                            how solid each find is.
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE72C;" FontSize="18"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                              VerticalAlignment="Top" Margin="0,2,0,0" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Built on Rust" FontWeight="SemiBold" />
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            The recovery engine is written in Rust — memory-safe, crash-resistant,
                            and fast. Legacy C/C++ recovery tools routinely corrupt results on
                            edge-case sectors. Rust prevents that class of bug entirely.
                        </TextBlock>
                    </StackPanel>
                </Grid>

            </StackPanel>
        </Expander>

        <!-- First-launch banner -->
        <InfoBar Grid.Row="1"
            IsOpen="{x:Bind ViewModel.ShowFirstLaunchBanner, Mode=TwoWay}"
            Severity="Warning"
            Title="Recover faster by acting now"
            Message="The sooner you recover, the better. Avoid saving new files to the same drive until recovery is complete."
            CloseButtonCommand="{x:Bind ViewModel.DismissBannerCommand}" />

        <!-- WHERE TO SCAN -->
        <StackPanel Grid.Row="2" Spacing="8">
            <TextBlock Text="WHERE TO SCAN"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontWeight="SemiBold" />

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16,14">
                <StackPanel Spacing="10">
                    <RadioButton x:Name="RadioEntireDrive"
                                 IsChecked="{x:Bind ViewModel.ScanEntireDrive, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEDA2;" FontSize="15"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="Entire Drive" FontWeight="SemiBold" />
                        </StackPanel>
                    </RadioButton>
                    <ComboBox IsEnabled="{x:Bind ViewModel.ScanEntireDrive, Mode=OneWay}"
                              ItemsSource="{x:Bind ViewModel.Drives}"
                              SelectedValuePath="Letter"
                              SelectedValue="{x:Bind ViewModel.SelectedDrive, Mode=TwoWay}"
                              HorizontalAlignment="Stretch" Margin="28,0,0,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:DriveEntry">
                                <TextBlock Text="{x:Bind DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <RadioButton IsChecked="{x:Bind ViewModel.ScanEntireDrive,
                                             Converter={StaticResource NegBoolConverter}, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8DA;" FontSize="15"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="Specific Folder" FontWeight="SemiBold" />
                        </StackPanel>
                    </RadioButton>
                    <Grid ColumnSpacing="8" Margin="28,0,0,0"
                          Visibility="{x:Bind ViewModel.ScanEntireDrive,
                                        Converter={StaticResource InverseBoolToVisConverter}, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" PlaceholderText="C:\Users\..."
                                 Text="{x:Bind ViewModel.CustomFolder, Mode=TwoWay}" />
                        <Button Grid.Column="1" Content="Browse" Click="BrowseFolder_Click" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- WHAT TO LOOK FOR -->
        <StackPanel Grid.Row="3" Spacing="8">
            <TextBlock Text="WHAT TO LOOK FOR"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontWeight="SemiBold" />
            <StackPanel Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ToggleButton CornerRadius="20" Padding="14,6"
                                  IsChecked="{x:Bind ViewModel.WantImages, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xEB9F;" FontSize="13" />
                            <TextBlock Text="Images" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton CornerRadius="20" Padding="14,6"
                                  IsChecked="{x:Bind ViewModel.WantVideos, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE714;" FontSize="13" />
                            <TextBlock Text="Videos" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton CornerRadius="20" Padding="14,6"
                                  IsChecked="{x:Bind ViewModel.WantDocuments, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8A5;" FontSize="13" />
                            <TextBlock Text="Documents" />
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ToggleButton CornerRadius="20" Padding="14,6"
                                  IsChecked="{x:Bind ViewModel.WantAudio, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8D6;" FontSize="13" />
                            <TextBlock Text="Audio" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton CornerRadius="20" Padding="14,6"
                                  IsChecked="{x:Bind ViewModel.WantArchives, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8B7;" FontSize="13" />
                            <TextBlock Text="Archives" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton CornerRadius="20" Padding="14,6"
                                  IsChecked="{x:Bind ViewModel.WantOther, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8CF;" FontSize="13" />
                            <TextBlock Text="Other" />
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- SCAN DEPTH -->
        <StackPanel Grid.Row="4" Spacing="8">
            <TextBlock Text="SCAN DEPTH"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontWeight="SemiBold" />
            <StackPanel Spacing="6">

                <!-- Quick Scan card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <RadioButton IsChecked="{x:Bind ViewModel.QuickScan, Mode=TwoWay}">
                        <StackPanel Spacing="2">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE945;" FontSize="16"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock Text="Quick Scan" FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock Text="MFT only · recently deleted files · 2–5 min"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Margin="24,0,0,0" />
                        </StackPanel>
                    </RadioButton>
                </Border>

                <!-- Deep Scan card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <RadioButton IsChecked="{x:Bind ViewModel.DeepScan, Mode=TwoWay}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8B3;" FontSize="16"
                                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                    <TextBlock Text="Deep Scan" FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock Text="MFT + raw carve · recommended for older deletions · hours"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Margin="24,0,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" CornerRadius="4" Padding="7,2"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="Recommended" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                            </Border>
                        </Grid>
                    </RadioButton>
                </Border>

                <!-- Raw Carve card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <RadioButton IsChecked="{x:Bind ViewModel.CarveOnly, Mode=TwoWay}">
                        <StackPanel Spacing="2">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7C3;" FontSize="16"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                <TextBlock Text="Raw Carve Only" FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock Text="Every sector · use if MFT found nothing or drive was formatted · hours"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       TextWrapping="Wrap"
                                       Margin="24,0,0,0" />
                        </StackPanel>
                    </RadioButton>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- Previous scans -->
        <StackPanel Grid.Row="5" Spacing="8">
            <TextBlock Text="PREVIOUS SCANS"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontWeight="SemiBold" />
            <TextBlock Text="No previous scans found."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       Visibility="{x:Bind ViewModel.Sessions.Count,
                                     Converter={StaticResource CountToInvVisConverter}, Mode=OneWay}" />
            <ListView ItemsSource="{x:Bind ViewModel.Sessions}"
                      SelectionMode="None"
                      Visibility="{x:Bind ViewModel.Sessions.Count,
                                    Converter={StaticResource CountToBoolToVisConverter}, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:ScanSession">
                        <Grid Padding="0,6,0,6" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xEDA2;" FontSize="14"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                      VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{x:Bind DisplayName}"
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="2" Content="Browse →"
                                    Command="{Binding ElementName=SetupPageRoot, Path=ViewModel.BrowseSessionCommand}"
                                    CommandParameter="{x:Bind}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

        <!-- Start button -->
        <Button Grid.Row="6"
                Command="{x:Bind ViewModel.StartScanCommand}"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Right"
                Padding="20,10">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE72A;" FontSize="14" />
                <TextBlock Text="Start Scan" />
            </StackPanel>
        </Button>
    </Grid>
    </ScrollViewer>
</Page>
