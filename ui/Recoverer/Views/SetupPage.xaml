<Page x:Class="Recoverer.Views.SetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:Recoverer.ViewModels">

    <Grid Margin="32,24,32,24" RowSpacing="20" MaxWidth="600">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- First-launch banner -->
        <InfoBar Grid.Row="0"
            IsOpen="{x:Bind ViewModel.ShowFirstLaunchBanner, Mode=TwoWay}"
            Severity="Warning"
            Title="Recover faster by acting now"
            Message="The sooner you recover, the better. Avoid saving new files to the same drive until recovery is complete."
            CloseButtonCommand="{x:Bind ViewModel.DismissBannerCommand}" />

        <!-- WHERE TO SCAN -->
        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock Text="WHERE TO SCAN" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <RadioButton x:Name="RadioEntireDrive" Content="Entire Drive"
                         IsChecked="{x:Bind ViewModel.ScanEntireDrive, Mode=TwoWay}" />
            <ComboBox IsEnabled="{x:Bind ViewModel.ScanEntireDrive, Mode=OneWay}"
                      ItemsSource="{x:Bind ViewModel.Drives}"
                      SelectedValuePath="Letter"
                      SelectedValue="{x:Bind ViewModel.SelectedDrive, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:DriveEntry">
                        <TextBlock Text="{x:Bind DisplayName}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <RadioButton Content="Specific Folder"
                         IsChecked="{x:Bind ViewModel.ScanEntireDrive,
                                     Converter={StaticResource NegBoolConverter}, Mode=TwoWay}" />
            <Grid ColumnSpacing="8"
                  Visibility="{x:Bind ViewModel.ScanEntireDrive,
                                Converter={StaticResource InverseBoolToVisConverter}, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" PlaceholderText="C:\Users\..."
                         Text="{x:Bind ViewModel.CustomFolder, Mode=TwoWay}" />
                <Button Grid.Column="1" Content="Browse"
                        Click="BrowseFolder_Click" />
            </Grid>
        </StackPanel>

        <!-- WHAT TO LOOK FOR -->
        <StackPanel Grid.Row="2" Spacing="8">
            <TextBlock Text="WHAT TO LOOK FOR" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="0">
                <CheckBox Content="Images"    IsChecked="{x:Bind ViewModel.WantImages, Mode=TwoWay}"    Margin="0,0,16,4" />
                <CheckBox Content="Videos"    IsChecked="{x:Bind ViewModel.WantVideos, Mode=TwoWay}"    Margin="0,0,16,4" />
                <CheckBox Content="Documents" IsChecked="{x:Bind ViewModel.WantDocuments, Mode=TwoWay}" Margin="0,0,16,4" />
                <CheckBox Content="Audio"     IsChecked="{x:Bind ViewModel.WantAudio, Mode=TwoWay}"     Margin="0,0,16,4" />
                <CheckBox Content="Archives"  IsChecked="{x:Bind ViewModel.WantArchives, Mode=TwoWay}"  Margin="0,0,16,4" />
                <CheckBox Content="Other"     IsChecked="{x:Bind ViewModel.WantOther, Mode=TwoWay}"     Margin="0,0,16,4" />
            </StackPanel>
        </StackPanel>

        <!-- SCAN DEPTH -->
        <StackPanel Grid.Row="3" Spacing="8">
            <TextBlock Text="SCAN DEPTH" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <RadioButton Content="Quick Scan (~2–5 min)  — finds recently deleted files"
                         IsChecked="{x:Bind ViewModel.DeepScan,
                                     Converter={StaticResource NegBoolConverter}, Mode=TwoWay}" />
            <RadioButton Content="Deep Scan (~15–45 min)  — recommended"
                         IsChecked="{x:Bind ViewModel.DeepScan, Mode=TwoWay}" />
        </StackPanel>

        <!-- Start button -->
        <Button Grid.Row="5" Content="Start Scan →"
                Command="{x:Bind ViewModel.StartScanCommand}"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Right"
                Padding="24,10" />
    </Grid>
</Page>
