<Page x:Class="Recoverer.Views.ScanningPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:Recoverer.ViewModels"
      xmlns:local="using:Recoverer.Controls">

    <Grid Margin="32,24,32,24" ColumnSpacing="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <!-- Left: progress + live feed -->
        <StackPanel Grid.Column="0" Spacing="16">

            <!-- Phase label -->
            <TextBlock Text="{x:Bind ViewModel.PhaseLabel, Mode=OneWay}"
                       Style="{StaticResource SubtitleTextBlockStyle}" />

            <!-- Progress bar + ETA -->
            <ProgressBar Value="{x:Bind ViewModel.Pct, Mode=OneWay}" Maximum="100" />
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{x:Bind ViewModel.Pct, Mode=OneWay, Converter={StaticResource PctConverter}}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Text="{x:Bind ViewModel.EtaText, Mode=OneWay}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                    <Run Text="{x:Bind ViewModel.FilesFound, Mode=OneWay}" />
                    <Run Text=" files found" />
                </TextBlock>
            </StackPanel>

            <!-- Pause/Cancel buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="{x:Bind ViewModel.IsPaused, Mode=OneWay,
                                  Converter={StaticResource PauseResumeTextConverter}}"
                        Command="{x:Bind ViewModel.PauseResumeCommand}" />
                <Button Content="Cancel" Command="{x:Bind ViewModel.CancelCommand}" />
            </StackPanel>

            <!-- Live discovery feed -->
            <TextBlock Text="DISCOVERED FILES" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <ListView x:Name="FeedList"
                      ItemsSource="{x:Bind ViewModel.Feed}"
                      Height="300"
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:DiscoveryItem">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{x:Bind Category}"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                       Width="80" />
                            <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

        <!-- Right: category breakdown -->
        <StackPanel Grid.Column="1" Spacing="12">
            <TextBlock Text="BY TYPE" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <local:CategoryRow Label="Images"    Count="{x:Bind ViewModel.ImagesCount, Mode=OneWay}"    Total="{x:Bind ViewModel.FilesFound, Mode=OneWay}" />
            <local:CategoryRow Label="Videos"    Count="{x:Bind ViewModel.VideosCount, Mode=OneWay}"    Total="{x:Bind ViewModel.FilesFound, Mode=OneWay}" />
            <local:CategoryRow Label="Documents" Count="{x:Bind ViewModel.DocumentsCount, Mode=OneWay}" Total="{x:Bind ViewModel.FilesFound, Mode=OneWay}" />
            <local:CategoryRow Label="Audio"     Count="{x:Bind ViewModel.AudioCount, Mode=OneWay}"     Total="{x:Bind ViewModel.FilesFound, Mode=OneWay}" />
            <local:CategoryRow Label="Archives"  Count="{x:Bind ViewModel.ArchivesCount, Mode=OneWay}"  Total="{x:Bind ViewModel.FilesFound, Mode=OneWay}" />
        </StackPanel>
    </Grid>
</Page>
