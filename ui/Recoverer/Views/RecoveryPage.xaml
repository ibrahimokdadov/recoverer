<Page x:Class="Recoverer.Views.RecoveryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="32,24,32,32" MaxWidth="600" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Same-volume warning -->
        <InfoBar Grid.Row="0"
                 IsOpen="{x:Bind ViewModel.ShowSameVolumeWarning, Mode=OneWay}"
                 Severity="Error"
                 Title="Same drive detected"
                 Message="Saving to the same drive could overwrite other recoverable files. Choose a different drive." />

        <!-- Destination picker -->
        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock Text="DESTINATION FOLDER"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontWeight="SemiBold" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14,12">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{x:Bind ViewModel.Destination, Mode=TwoWay}"
                             PlaceholderText="D:\Recovered Files"
                             BorderThickness="0" Background="Transparent" />
                    <Button Grid.Column="1" Content="Browse"
                            Click="BrowseDestination_Click" />
                </Grid>
            </Border>
        </StackPanel>

        <!-- Options -->
        <StackPanel Grid.Row="2" Spacing="8">
            <TextBlock Text="OPTIONS"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontWeight="SemiBold" />
            <CheckBox Content="Recreate original folder structure"
                      IsChecked="{x:Bind ViewModel.RecreateStructure, Mode=TwoWay}" />
        </StackPanel>

        <!-- File summary -->
        <Border Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="14,12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE8FD;" FontSize="16"
                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <TextBlock VerticalAlignment="Center">
                    <Run Text="{x:Bind ViewModel.Total, Mode=OneWay}" FontWeight="SemiBold" />
                    <Run Text=" files selected for recovery" />
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Progress / Result -->
        <StackPanel Grid.Row="4" Spacing="16">

            <!-- In-progress -->
            <StackPanel Visibility="{x:Bind ViewModel.IsRecovering, Mode=OneWay,
                                      Converter={StaticResource BoolToVisConverter}}"
                        Spacing="12">
                <ProgressBar Maximum="100"
                             Value="{x:Bind ViewModel.ProgressPct, Mode=OneWay}" />

                <!-- Stat cards -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="8" Padding="14,10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{x:Bind ViewModel.Recovered, Mode=OneWay}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#3DB87A" />
                            <TextBlock Text="Recovered"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" CornerRadius="8" Padding="14,10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{x:Bind ViewModel.Warnings, Mode=OneWay}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#E0A020" />
                            <TextBlock Text="Low confidence"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" CornerRadius="8" Padding="14,10"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{x:Bind ViewModel.Failed, Mode=OneWay}"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="#D95858" />
                            <TextBlock Text="Failed"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Button Content="Cancel Remaining"
                        Command="{x:Bind ViewModel.CancelRecoveryCommand}" />
            </StackPanel>

            <!-- Complete -->
            <StackPanel Visibility="{x:Bind ViewModel.IsComplete, Mode=OneWay,
                                      Converter={StaticResource BoolToVisConverter}}"
                        Spacing="16">
                <Border CornerRadius="8" Padding="20,16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE73E;" FontSize="22" Foreground="#3DB87A" />
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}">
                                <Run Text="{x:Bind ViewModel.Recovered, Mode=OneWay}" FontWeight="Bold" />
                                <Run Text=" files recovered" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,4,0,0">
                            <TextBlock Foreground="#E0A020" Style="{StaticResource CaptionTextBlockStyle}">
                                <Run Text="{x:Bind ViewModel.Warnings, Mode=OneWay}" />
                                <Run Text=" low confidence" />
                            </TextBlock>
                            <TextBlock Foreground="#D95858" Style="{StaticResource CaptionTextBlockStyle}">
                                <Run Text="{x:Bind ViewModel.Failed, Mode=OneWay}" />
                                <Run Text=" failed" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="OpenExplorer_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xEC50;" FontSize="14" />
                            <TextBlock Text="View in Explorer" />
                        </StackPanel>
                    </Button>
                    <Button Click="ScanAgain_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72A;" FontSize="14" />
                            <TextBlock Text="Scan Again" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Start button -->
            <Button Command="{x:Bind ViewModel.StartRecoveryCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Right"
                    Padding="20,10"
                    Visibility="{x:Bind ViewModel.CanStartRecovery, Mode=OneWay,
                                  Converter={StaticResource BoolToVisConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE896;" FontSize="14" />
                    <TextBlock Text="Start Recovery" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Page>
