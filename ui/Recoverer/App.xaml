<Application
    x:Class="Recoverer.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Recoverer">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Override accent color to match brand ──────────────── -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <Color x:Key="AccentColor">#3A9FDB</Color>
                    <SolidColorBrush x:Key="SystemControlHighlightAccentBrush"
                                     Color="{StaticResource AccentColor}" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="AccentColor">#3A9FDB</Color>
                    <SolidColorBrush x:Key="SystemControlHighlightAccentBrush"
                                     Color="{StaticResource AccentColor}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- ── Converters ─────────────────────────────────────────── -->
            <local:InverseBoolConverter          x:Key="NegBoolConverter" />
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter" />
            <local:BoolToVisibilityConverter     x:Key="BoolToVisConverter" />
            <local:NullToVisibilityConverter     x:Key="NullToVisConverter" />
            <local:PauseResumeTextConverter      x:Key="PauseResumeTextConverter" />
            <local:PercentConverter              x:Key="PctConverter" />
            <local:FileSizeConverter             x:Key="FileSizeConverter" />
            <local:CountToBoolConverter          x:Key="CountToBoolConverter" />

            <!-- ── Brand colors ──────────────────────────────────────── -->
            <Color x:Key="AccentColor">#3A9FDB</Color>
            <Color x:Key="SuccessColor">#3DB87A</Color>
            <Color x:Key="WarningColor">#E0A020</Color>
            <Color x:Key="ErrorColor">#D95858</Color>

            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
            <SolidColorBrush x:Key="ErrorBrush"   Color="{StaticResource ErrorColor}" />

            <!-- ── Spacing / geometry ────────────────────────────────── -->
            <CornerRadius x:Key="CardCornerRadius">6</CornerRadius>
            <CornerRadius x:Key="ControlCornerRadius">4</CornerRadius>
            <Thickness x:Key="PageMargin">32,24,32,24</Thickness>
        </ResourceDictionary>
    </Application.Resources>
</Application>
