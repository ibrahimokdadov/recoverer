<Application
    x:Class="Recoverer.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Recoverer">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <local:NullToVisibilityConverter x:Key="NullToVisConverter" />
            <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter" />
            <local:InverseBoolConverter x:Key="NegBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
